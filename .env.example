# 로컬(docker compose): 아래 기본값 사용
# Railway 배포: Postgres 플러그인을 붙이면 DATABASE_URL이 자동 주입되므로 직접 설정할 필요 없음
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ai_academy_advisor

# Railway 대시보드 > Variables에서 직접 설정 (프로덕션 값은 여기에 커밋하지 말 것)
OPENAI_API_KEY=
GROQ_API_KEY=
# Groq Chat Completions는 OpenAI 호환 REST — 기본값 그대로 두면 된다.
GROQ_BASE_URL=https://api.groq.com/openai/v1
SECRET_KEY=

# AI provider 선택 (기본값은 전부 stub — 실제 호출/키 없이 동작).
# LLM_PROVIDER=groq로 켜면 무료 Groq(Llama)를 사용한다. 이때 LLM_MODEL도
# Groq 모델명(예: llama-3.3-70b-versatile)으로 바꿔야 한다.
# 임베딩/벡터스토어(openai/bge-m3/pgvector)는 아직 stub — 다음 단계에서 추가된다.
LLM_PROVIDER=stub
EMBEDDING_PROVIDER=stub
VECTOR_STORE=stub
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=BAAI/bge-m3
# 임베딩 차원 (Review.embedding 의 Vector(dim)과 일치해야 함; 변경 시 마이그레이션 필요)
EMBEDDING_DIM=1024
